# Dockerfile para desarrollo con hot-reload
FROM node:22-alpine

WORKDIR /app

# Instalar dependencias globales útiles para desarrollo
RUN apk add --no-cache git

# Copiar archivos de configuración de dependencias
COPY package.json yarn.lock ./

# Instalar TODAS las dependencias (incluyendo dev)
RUN yarn install

# Copiar archivos de configuración necesarios para el build
COPY tsconfig.json tsconfig.build.json nest-cli.json ./

# Crear directorio para archivos públicos
RUN mkdir -p /app/public

# Exponer el puerto
EXPOSE 3000

# Configurar variables de entorno para hot-reload
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true

# Comando para iniciar en modo desarrollo con watch (usar script específico para Docker)
CMD ["yarn", "start:dev:docker"]
