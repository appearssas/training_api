DATABASE_HOST=your-database-host.com
DATABASE_PORT=your-database-port
DATABASE_USER=your-database-username
DATABASE_PASSWORD=your-database-password
DATABASE_NAME=your-database-name

JWT_SECRET=your-jwt-secret
HOST_URL=your_host_url
STAGE=dev

# Application Configuration (STAGE: prod | dev)
PORT=3000

# Redis (opcional; para BullMQ en aprobaciones masivas)
# Si REDIS_ENABLED no es true, el bulk se ejecuta en síncrono sin Redis
# REDIS_ENABLED=true
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Email Configuration
MAIL_HOST=mail.qinspecting.com
MAIL_PORT=465
MAIL_SECURE=false
MAIL_USER=soporte@qinspecting.com
MAIL_PASSWORD=your-email-password
MAIL_FROM="Sistema de Capacitaciones <noreply@capacitaciones.com>"

# Password Reset Configuration
PASSWORD_RESET_TOKEN_EXPIRY=3600
FRONTEND_URL="http://localhost:8080#"

# Assistant: al menos una API key. Orden de uso con fallback: ASSISTANT_PROVIDER_ORDER (default: perplexity,openai,gemini)
# Perplexity: https://perplexity.ai/settings → "</> API"
PERPLEXITY_API_KEY=
# OPENAI (pago por tokens)
OPENAI_API_KEY=
# Gemini (tier gratuito con límites): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# ASSISTANT_PROVIDER_ORDER=perplexity,openai,gemini
# PERPLEXITY_MODEL=sonar
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# Límites para no superar la capa gratuita (0 = sin límite)
# Tokens totales por mes: al alcanzar, no se hacen más peticiones hasta el mes siguiente
ASSISTANT_MONTHLY_TOKEN_LIMIT=1000
# Peticiones máximas por día (opcional)
ASSISTANT_DAILY_REQUEST_LIMIT=30

# Exportación masiva de usuarios (GET /users/export, scope=all): tope de filas antes de 413
# USERS_EXPORT_MAX_ROWS=100000

# Exportación masiva de certificados (GET /certificados/export, scope=all): tope de filas antes de 413
# CERTIFICATES_EXPORT_MAX_ROWS=100000

